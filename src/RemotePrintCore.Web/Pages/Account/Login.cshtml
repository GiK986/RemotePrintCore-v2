@page
@model RemotePrintCore.Web.Pages.Account.LoginModel
<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login — RemotePrintCore</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: Roboto, sans-serif; background: #f5f5f5; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
        .card { background: #fff; border-radius: 8px; box-shadow: 0 2px 12px rgba(0,0,0,.12); padding: 40px; width: 360px; }
        h1 { font-size: 1.4rem; font-weight: 500; margin-bottom: 8px; color: #594ae2; }
        .subtitle { font-size: .875rem; color: #666; margin-bottom: 28px; }
        label { display: block; font-size: .8rem; font-weight: 500; color: #555; margin-bottom: 4px; margin-top: 16px; }
        input[type=text], input[type=password] { width: 100%; padding: 10px 12px; border: 1px solid #ccc; border-radius: 4px; font-size: .95rem; outline: none; transition: border-color .2s; }
        input:focus { border-color: #594ae2; }
        .remember { display: flex; align-items: center; gap: 8px; margin-top: 14px; font-size: .875rem; color: #555; }
        button { width: 100%; margin-top: 24px; padding: 11px; background: #594ae2; color: #fff; border: none; border-radius: 4px; font-size: 1rem; font-weight: 500; cursor: pointer; transition: background .2s; }
        button:hover { background: #4a3db8; }
        .error { margin-top: 14px; padding: 10px 12px; background: #fdecea; color: #c62828; border-radius: 4px; font-size: .875rem; }
    </style>
</head>
<body>
    <div class="card">
        <h1>RemotePrintCore</h1>
        <p class="subtitle">Sign in to continue</p>
        <form method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="error" style="display:@(Model.ErrorMessage != null ? "block" : "none")">
                @Model.ErrorMessage
            </div>
            <label asp-for="Input.UserName">Username</label>
            <input asp-for="Input.UserName" autocomplete="username" autofocus />
            <label asp-for="Input.Password">Password</label>
            <input asp-for="Input.Password" type="password" autocomplete="current-password" />
            <div class="remember">
                <input asp-for="Input.RememberMe" type="checkbox" />
                <label asp-for="Input.RememberMe" style="margin:0">Remember me</label>
            </div>
            <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
            <button type="submit">Sign In</button>
        </form>
    </div>
</body>
</html>
